<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AELLGANK🦅 - Login</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            background: linear-gradient(135deg, #0a0e1a 0%, #0f172a 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        
        .container {
            max-width: 420px;
            width: 100%;
        }
        
        .card {
            background: #111827;
            border-radius: 24px;
            padding: 40px;
            border: 1px solid #1f2937;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        
        .logo {
            text-align: center;
            margin-bottom: 32px;
        }
        
        .logo img {
            max-width: 120px;
            height: auto;
            margin-bottom: 12px;
        }
        
        .logo h1 {
            font-size: 36px;
            margin-bottom: 8px;
        }
        
        .logo .aellgank {
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .logo p {
            color: #6b7280;
            font-size: 14px;
        }
        
        .input-group {
            margin-bottom: 20px;
        }
        
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #9ca3af;
            font-size: 14px;
            font-weight: 500;
        }
        
        .input-group input {
            width: 100%;
            padding: 14px 16px;
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 12px;
            color: #f3f4f6;
            font-size: 15px;
            transition: all 0.2s;
        }
        
        .input-group input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        }
        
        .input-group input::placeholder {
            color: #4b5563;
        }
        
        button {
            width: 100%;
            padding: 14px;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
        }
        
        button:hover:not(:disabled) {
            background: #2563eb;
            transform: translateY(-1px);
        }
        
        button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
        
        .result {
            margin-top: 20px;
            padding: 14px;
            border-radius: 12px;
            display: none;
            font-size: 14px;
            animation: fadeIn 0.3s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .result.success {
            display: block;
            background: rgba(34,197,94,0.15);
            border: 1px solid #22c55e;
            color: #86efac;
        }
        
        .result.error {
            display: block;
            background: rgba(239,68,68,0.15);
            border: 1px solid #ef4444;
            color: #fca5a5;
        }
        
        .spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 0.6s linear infinite;
            margin-right: 8px;
            vertical-align: middle;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .loading-container {
            margin-top: 16px;
            text-align: center;
        }
        
        .loading-bar {
            height: 3px;
            background: #1f2937;
            border-radius: 3px;
            overflow: hidden;
            margin-top: 12px;
        }
        
        .loading-progress {
            width: 0%;
            height: 100%;
            background: #3b82f6;
            border-radius: 3px;
            transition: width 0.1s linear;
        }
        
        .loading-text {
            font-size: 12px;
            color: #6b7280;
            margin-top: 8px;
        }
        
        .info-text {
            text-align: center;
            margin-top: 24px;
            font-size: 12px;
            color: #4b5563;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="logo">
                <img src="/uploads/logo.jpg" alt="AELLGANK Logo" onerror="this.src='https://via.placeholder.com/120x40?text=AELLGANK'">
                <h1><span class="aellgank">AELLGANK</span> 🦅</h1>
                <p>Login to your account</p>
            </div>
            
            <form id="loginForm">
                <div class="input-group">
                    <label>Username</label>
                    <input type="text" id="username" placeholder="Enter username" autocomplete="off" required>
                </div>
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" id="password" placeholder="Enter password" required>
                </div>
                <button type="submit" id="submitBtn">Login</button>
            </form>
            
            <div id="result" class="result"></div>
            <div id="loadingContainer" class="loading-container" style="display: none;">
                <div class="loading-bar">
                    <div class="loading-progress" id="loadingProgress"></div>
                </div>
                <div class="loading-text" id="loadingText">Verifying credentials...</div>
            </div>
            
            <div class="info-text">
                🔒 Secure login system by AELLGANK Security
            </div>
        </div>
    </div>
    
    <script>
        const form = document.getElementById('loginForm');
        const usernameInput = document.getElementById('username');
        const passwordInput = document.getElementById('password');
        const submitBtn = document.getElementById('submitBtn');
        const resultDiv = document.getElementById('result');
        const loadingContainer = document.getElementById('loadingContainer');
        const loadingProgress = document.getElementById('loadingProgress');
        const loadingText = document.getElementById('loadingText');
        
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const username = usernameInput.value.trim();
            const password = passwordInput.value.trim();
            
            if (!username || !password) {
                showResult('error', 'Isi username & password dulu!');
                return;
            }
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner"></span> Processing...';
            loadingContainer.style.display = 'block';
            
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 15;
                if (progress > 90) progress = 90;
                loadingProgress.style.width = progress + '%';
            }, 100);
            
            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, password })
                });
                
                const data = await response.json();
                clearInterval(interval);
                loadingProgress.style.width = '100%';
                
                if (data.success) {
                    loadingText.textContent = 'Redirecting...';
                    showResult('success', `✅ Login successful! Redirecting in ${data.delay} seconds...`);
                    
                    usernameInput.value = '';
                    passwordInput.value = '';
                    
                    setTimeout(() => {
                        window.location.href = 'https://garena.com';
                    }, data.delay * 1000);
                } else {
                    showResult('error', '❌ ' + data.message);
                    resetButton();
                }
            } catch (error) {
                clearInterval(interval);
                showResult('error', '❌ Network error! Coba lagi.');
                resetButton();
            }
        });
        
        function showResult(type, message) {
            resultDiv.className = `result ${type}`;
            resultDiv.innerHTML = message;
            setTimeout(() => {
                if (type === 'success') {
                    resultDiv.style.display = 'none';
                }
            }, 5000);
        }
        
        function resetButton() {
            setTimeout(() => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Login';
                loadingContainer.style.display = 'none';
                loadingProgress.style.width = '0%';
            }, 2000);
        }
    </script>
</body>
</html>
