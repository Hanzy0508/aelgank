<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AELLGANK🦅 - Shortlink Gallery</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', -apple-system, sans-serif;
            background: #0a0e1a;
            color: #f3f4f6;
        }
        .app { display: flex; min-height: 100vh; }
        .sidebar {
            width: 280px;
            background: #0f172a;
            border-right: 1px solid #1e293b;
            padding: 24px 16px;
            position: fixed;
            height: 100vh;
        }
        .logo { text-align: center; padding-bottom: 24px; margin-bottom: 24px; border-bottom: 1px solid #1e293b; }
        .logo img { max-width: 120px; height: auto; margin-bottom: 12px; }
        .logo h2 {
            font-size: 24px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .nav-menu { display: flex; flex-direction: column; gap: 4px; }
        .nav-item {
            padding: 10px 16px;
            color: #94a3b8;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            display: block;
        }
        .nav-item:hover, .nav-item.active { background: #1e293b; color: #3b82f6; }
        .nav-divider { height: 1px; background: #1e293b; margin: 16px 0; }
        .main { flex: 1; margin-left: 280px; padding: 24px 32px; }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding-bottom: 16px;
            border-bottom: 1px solid #1e293b;
        }
        .user-email { color: #94a3b8; font-size: 14px; }
        .logout-btn {
            background: #1e293b;
            color: #ef4444;
            padding: 8px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            margin-left: 16px;
        }
        .table-container {
            background: #111827;
            border: 1px solid #1f2937;
            border-radius: 16px;
            overflow-x: auto;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 16px; text-align: left; border-bottom: 1px solid #1f2937; }
        th { color: #94a3b8; font-weight: 500; font-size: 13px; }
        td { font-size: 14px; }
        .shortlink-url { color: #3b82f6; text-decoration: none; cursor: pointer; }
        .copy-btn { background: #1e293b; color: #3b82f6; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; }
        .empty-state { text-align: center; padding: 48px; color: #6b7280; }
        .back-link { display: inline-block; margin-top: 16px; color: #3b82f6; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <div class="app">
        <div class="sidebar">
            <div class="logo">
                <img src="/uploads/logo.jpg" alt="AELLGANK Logo" onerror="this.src='https://via.placeholder.com/120x40?text=AELLGANK'">
                <h2>AELLGANK 🦅</h2>
            </div>
            <div class="nav-menu">
                <a href="/admin/dashboard" class="nav-item">📊 Dashboard</a>
                <a href="/admin/create-web" class="nav-item">➕ Create Web</a>
                <a href="/admin/my-webs" class="nav-item">🌐 My Webs</a>
                <a href="/admin/create-shortlink" class="nav-item">🔗 Create Shortlink</a>
                <a href="/admin/my-shortlinks" class="nav-item">📎 My Shortlinks</a>
                <a href="/admin/template-gallery" class="nav-item">🎨 Template Gallery</a>
                <a href="/admin/shortlink-gallery" class="nav-item active">🔗 Shortlink Gallery</a>
                <div class="nav-divider"></div>
                <a href="/admin/settings" class="nav-item">⚙️ Settings</a>
            </div>
        </div>
        
        <div class="main">
            <div class="header">
                <h1>Shortlink Gallery</h1>
                <div><span class="user-email"><%= admin.email %></span><a href="/admin/logout" class="logout-btn">Logout</a></div>
            </div>
            
            <div class="table-container">
                <table>
                    <thead>
                        <tr><th>Short URL</th><th>Original URL</th><th>Slug</th><th>Clicks</th><th>Created By</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        <% if (shortlinks.length === 0) { %>
                            <tr><td colspan="6" class="empty-state">Belum ada shortlink</span></td></tr>
                        <% } else { %>
                            <% shortlinks.forEach(link => { %>
                            <tr>
                                <td><a href="#" class="shortlink-url" onclick="copyToClipboard('<%= link.shortUrl %>')"><%= link.shortUrl %></a></span>
                                <td><code style="font-size:12px"><%= link.originalUrl.substring(0, 50) %>...</code></span>
                                <td><%= link.slug %></span>
                                <td><%= link.clicks || 0 %></span>
                                <td><%= link.createdBy %></span>
                                <td><button class="copy-btn" onclick="copyToClipboard('<%= link.shortUrl %>')">Copy</button></span>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <a href="/admin/dashboard" class="back-link">← Back to Dashboard</a>
        </div>
    </div>
    
    <script>
        function copyToClipboard(text) { navigator.clipboard.writeText(text); alert('Shortlink copied!'); }
    </script>
</body>
</html>